~ FizzBuzz — shows signals (functions), when/elsewhen/otherwise,
~ each-in loops, and range().

signal fizzbuzz(n) {
  each i in range(1, n + 1) {
    when (i % 15 == 0) {
      beam "FizzBuzz"
    } elsewhen (i % 3 == 0) {
      beam "Fizz"
    } elsewhen (i % 5 == 0) {
      beam "Buzz"
    } otherwise {
      beam i
    }
  }
}

fizzbuzz(15)
